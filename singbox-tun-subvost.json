{
  "log": {
    "level": "debug",
    "timestamp": true
  },
  "dns": {
    "strategy": "ipv4_only",
    "servers": [
      {
        "type": "udp",
        "server": "8.8.8.8",
        "server_port": 53,
        "detour": "direct",
        "tag": "dns-direct"
      }
    ]
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7897
    },
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.19.0.1/30"
      ],
      "mtu": 1500,
      "auto_route": true,
      "auto_redirect": true,
      "strict_route": true,
      "stack": "mixed",
      "exclude_uid": [
        0
      ]
    }
  ],
  "outbounds": [
    {
      "type": "socks",
      "tag": "proxy",
      "server": "127.0.0.1",
      "server_port": 10808,
      "udp_fragment": true,
      "domain_resolver": {
        "server": "dns-direct",
        "strategy": "prefer_ipv4"
      }
    },
    {
      "type": "direct",
      "tag": "direct",
      "domain_resolver": {
        "server": "dns-direct",
        "strategy": "prefer_ipv4"
      }
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "final": "proxy",
    "rules": [
      {
        "outbound": "direct",
        "process_name": [
          "xray",
          "sing-box",
          "antifilter"
        ]
      },
      {
        "action": "sniff"
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "action": "route",
        "domain_suffix": [
          ".ru"
        ],
        "outbound": "direct"
      }
    ]
  }
}
