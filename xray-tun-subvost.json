      "port": 10808,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      }
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "45.137.69.71",
            "port": 443,
            "users": [
              {
                "id": "REPLACE_WITH_REALITY_UUID",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "sockopt": {
          "interface": "eth0"
        },
        "realitySettings": {
          "serverName": "fn.video.subvost.fun",
          "fingerprint": "chrome",
          "publicKey": "REPLACE_WITH_REALITY_PUBLIC_KEY",
          "shortId": "REPLACE_WITH_REALITY_SHORT_ID",
          "spiderX": "/"
        },
        "xhttpSettings": {
          "host": "fn.video.subvost.fun",
          "path": "/",
          "mode": "auto",
          "extra": {
            "xmux": {
              "cMaxReuseTimes": 0,
              "maxConcurrency": "16-32",
              "maxConnections": 0,
              "hKeepAlivePeriod": 0,
              "hMaxRequestTimes": "600-900",
              "hMaxReusableSecs": "1800-3000"
            },
            "headers": {},
            "noGRPCHeader": false,
            "xPaddingBytes": "100-1000",
            "scMaxEachPostBytes": 1000000,
            "scMinPostsIntervalMs": 30,
            "scStreamUpServerSecs": "20-80"
          }
        }
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom",
      "streamSettings": {
        "sockopt": {
          "interface": "eth0"
        }
      }
    },
    {
      "tag": "block",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "inboundTag": [
